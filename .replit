run = "python main.py"
entrypoint = "main.py"
language = "python3"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "python main.py"]
deploymentTarget = "autoscale"
ignorePorts = false

[[ports]]
localPort = 8000
externalPort = 80

[env]
PYTHONUNBUFFERED = "1"
APP_ENV = "production"
