# ══════════════════════════════════════════════════════════════════════
#  MediPackages OCR Server — Environment Configuration
#  For Replit: Set these as Secrets (padlock icon in sidebar)
# ══════════════════════════════════════════════════════════════════════

# ── REQUIRED: Set in Replit Secrets ────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
API_AUTH_TOKEN=

# ── Models ─────────────────────────────────────────────────────────────
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_MODEL=gemini-1.5-flash

# ── LLM Settings ──────────────────────────────────────────────────────
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Server (PORT is auto-set by Replit) ────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
MAX_UPLOAD_MB=20
RATE_LIMIT_RPM=60

# ── Package Matching ──────────────────────────────────────────────────
TOP_K_PACKAGES=5

# ── Paths ─────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
MEMORY_DB=./memory/agent_memory.db

# ── Optional ──────────────────────────────────────────────────────────
USE_LOCAL_LLM=false
USE_EASYOCR=false
OCR_LANGUAGES=en
OCR_GPU=false

# ── Security / CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
TRUSTED_HOSTS=*
ENABLE_DOCS=false
APP_ENV=production
SERVER_WORKERS=1
